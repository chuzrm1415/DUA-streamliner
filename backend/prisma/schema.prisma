// This is the Prisma schema for the DUA Streamliner backend.
// Run `prisma migrate dev` to apply migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  azureId      String   @unique                 // Azure Entra ID object ID
  email        String   @unique
  name         String
  role         UserRole @default(CUSTOMS_AGENT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Session[]

  @@map("users")
}

enum UserRole {
  MANAGER
  CUSTOMS_AGENT
}

// ─────────────────────────────────────────────
// Processing Sessions
// ─────────────────────────────────────────────
model Session {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  status      SessionStatus @default(PENDING)
  progress    Int           @default(0)          // 0–100
  error       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  completedAt DateTime?

  documents   Document[]
  job         ProcessingJob?
  duaData     DuaData?

  @@index([userId])
  @@index([status])
  @@map("sessions")
}

enum SessionStatus {
  PENDING
  UPLOADING
  PROCESSING
  GENERATING
  REVIEW
  FINALIZED
  FAILED
}

// ─────────────────────────────────────────────
// Documents (uploaded files)
// ─────────────────────────────────────────────
model Document {
  id            String         @id @default(uuid())
  sessionId     String
  session       Session        @relation(fields: [sessionId], references: [id])
  originalName  String
  mimeType      String
  sizeBytes     Int
  blobPath      String                           // path in Azure Blob Storage
  format        DocumentFormat
  status        DocumentStatus @default(PENDING)
  extractedText String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([sessionId])
  @@map("documents")
}

enum DocumentFormat {
  PDF
  DOCX
  XLSX
  IMAGE
}

enum DocumentStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
}

// ─────────────────────────────────────────────
// Processing Jobs (BullMQ tracking)
// ─────────────────────────────────────────────
model ProcessingJob {
  id          String    @id @default(uuid())
  sessionId   String    @unique
  session     Session   @relation(fields: [sessionId], references: [id])
  bullJobId   String?                           // BullMQ job id
  status      JobStatus @default(PENDING)
  retryCount  Int       @default(0)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@map("processing_jobs")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  FINALIZED
}

// ─────────────────────────────────────────────
// DUA Data (extracted fields)
// ─────────────────────────────────────────────
model DuaData {
  id          String     @id @default(uuid())
  sessionId   String     @unique
  session     Session    @relation(fields: [sessionId], references: [id])
  fields      Json                              // DuaField[]
  status      DuaStatus  @default(PRELIMINARY)
  blobPath    String?                           // generated .docx path
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("dua_data")
}

enum DuaStatus {
  PRELIMINARY
  FINAL
}
